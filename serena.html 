const CRISIS_WORDS = [“suicid”, “morir”, “matarme”, “hacerme daño”, “no quiero vivir”, “autolesion”, “cortarme”];
const REFER_WORDS = [“semanas”, “meses”, “siempre”, “nunca mejora”, “no puedo más”, “ayuda profesional”, “terapeuta”, “psicólogo”];

let responseIndex = 0;

async function callClaude({ system, messages, maxTokens = 500 }) {
// Detectar crisis
const lastMsg = messages[messages.length - 1]?.content?.toLowerCase() || “”;
if (CRISIS_WORDS.some(w => lastMsg.includes(w))) {
return “Gracias por contarme esto. Lo que describes me preocupa y quiero que sepas que no estás solo/a. Por favor contacta ahora con una línea de ayuda — hay personas preparadas para acompañarte. [CRISIS]”;
}
// Detectar derivación
if (REFER_WORDS.some(w => lastMsg.includes(w))) {
const resp = SERENA_RESPONSES[responseIndex % SERENA_RESPONSES.length];
responseIndex++;
return resp + “ Dado lo que me cuentas, creo que hablar con uno de nuestros psicólogos podría ayudarte mucho. [REFER]”;
}
// Respuesta normal
const resp = SERENA_RESPONSES[responseIndex % SERENA_RESPONSES.length];
responseIndex++;
return resp;
}

