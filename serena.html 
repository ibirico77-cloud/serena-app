const addPsych=useCallback((p)=>{setPsychologists(prev=>{const ex=prev.find(x=>x.id===p.id);return ex?prev.map(x=>x.id===p.id?p:x):[…prev,p];});},[]);
const pages={home:<HomePage setPage={setPage} showCrisis={()=>setCrisis(true)} moodDone={moodDone} setMoodDone={setMoodDone}/>,community:<CommunityPage showCrisis={()=>setCrisis(true)}/>,chat:<ChatPage showCrisis={()=>setCrisis(true)} setPage={setPage} psychologists={psychologists}/>,library:<LibraryPage extra={extraDisorders}/>,tools:<ToolsPage/>,psychologists:<PsychologistsPage psychologists={psychologists}/>,portal:<PsychPortal onPublish={d=>setExtraDisorders(p=>[…p,d])} onAddPsych={addPsych}/>};
return(<><style>{CSS}</style><div className="app">{pages[page]||pages.home}<nav className="bnav">{NAV.map(n=>(<button key={n.id} className={`nb${page===n.id?" on":""}`} onClick={()=>setPage(n.id)}>{n.icon}{n.l}</button>))}</nav>{crisis&&<CrisisModal onClose={()=>setCrisis(false)}/>}</div></>);
}

const root = ReactDOM.createRoot(document.getElementById(‘root’));
root.render(React.createElement(App));
</script>

</body>
</html>