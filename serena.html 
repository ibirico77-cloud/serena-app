function ChatPage({showCrisis,setPage,psychologists}){
const[msgs,setMsgs]=useState([{role:“ai”,text:“Hola, soy Serena 🌿 Estoy aquí para escucharte, informarte y acompañarte. Puedo contarte sobre trastornos mentales, técnicas de bienestar o simplemente escucharte. ¿Cómo estás hoy?”}]);
const[input,setInput]=useState(””);const[loading,setLoading]=useState(false);
const ref=useRef(null);
useEffect(()=>ref.current?.scrollIntoView({behavior:“smooth”}),[msgs]);
const send=useCallback(async()=>{
if(!input.trim()||loading)return;
const txt=input.trim();setInput(””);setLoading(true);
setMsgs(p=>[…p,{role:“user”,text:txt}]);
try{
const history=msgs.filter(m=>m.role!==“ref”).map(m=>({role:m.role===“ai”?“assistant”:“user”,content:m.text}));
const raw=await callClaude({system:SERENA_PROMPT,messages:[…history,{role:“user”,content:txt}],maxTokens:500});
const isCrisis=raw.includes(”[CRISIS]”);const isRef=raw.includes(”[REFER]”);
const clean=raw.replace(”[CRISIS]”,””).replace(”[REFER]”,””).trim();
const add=[{role:“ai”,text:clean}];
if(isRef)add.push({role:“ref”,text:””});
setMsgs(p=>[…p,…add]);
if(isCrisis)setTimeout(showCrisis,800);
}catch(e){setMsgs(p=>[…p,{role:“ai”,text:`Error de conexión: ${e.message} 🌿`}]);}
finally{setLoading(false);}
},[input,loading,msgs,showCrisis]);
return(
<div style={{display:“flex”,flexDirection:“column”,height:“100vh”,maxWidth:430,margin:“0 auto”,background:“var(–bg)”}}>
