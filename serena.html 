useEffect(()=>ref.current?.scrollIntoView({behavior:“smooth”}),[msgs,warn]);
const doSend=useCallback((txt)=>{const now=new Date();const t=`${now.getHours()}:${String(now.getMinutes()).padStart(2,"0")}`;setMsgs(p=>[…p,{id:Date.now(),alias:“Tú”,emoji:“😊”,text:txt,time:t,mine:true}]);setWarn(null);setPending(””);setInput(””);},[]);
